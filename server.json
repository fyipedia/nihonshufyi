    "url": "https://github.com/fyipedia/nihonshufyi",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "nihonshufyi",
      "version": "0.1.4",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "named",
          "name": "--from",
          "value": "nihonshufyi[mcp]"
        },
        {
          "type": "positional",
          "value": "python"
        },
        {
          "type": "positional",
          "value": "-m"
        },
        {
          "type": "positional",
          "value": "nihonshufyi.mcp_server"
        }
      ]
    }
  ]
